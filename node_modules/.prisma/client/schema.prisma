generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  salt         String
  createdAt    DateTime @default(now())
  player       Player?
}

model Player {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  class            String
  gender           String
  level            Int      @default(1)
  xp               Int      @default(0)
  hp               Int
  maxHp            Int
  baseStats        Json
  stats            Json
  statusOverrides  Json?
  role             String   @default("player")
  inventory        Json
  equippedWeaponId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Item {
  id      String @id @default(cuid())
  name    String
  type    String
  slot    String
  bonuses Json
}

model MobTemplate {
  id              String @id @default(cuid())
  kind            String
  maxHp           Int
  size            Int
  color           String
  xpReward        Int
  physicalDefense Int
  magicDefense    Int
}

model WorldLog {
  id        String   @id @default(cuid())
  level     String
  event     String
  data      Json
  createdAt DateTime @default(now())
}
