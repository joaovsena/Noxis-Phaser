{
  "name": "sena",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:server": "tsc",
    "build:client": "vite build --config client/vite.config.ts",
    "start": "node dist/server/index.js",
    "dev": "ts-node server/index.ts",
    "client:dev": "vite --config client/vite.config.ts",
    "docker:up": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-up.ps1",
    "docker:poc:up": "docker compose --profile poc up --build -d engine-go",
    "docker:poc:down": "docker compose --profile poc down",
    "docker:down": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-down.ps1",
    "docker:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-reset.ps1",
    "docker:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-logs.ps1",
    "setup:legacy": "node scripts/setup-legacy-project.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset",
    "dev:setup": "npm run db:reset && npm run db:generate",
    "test": "jest",
    "bench:engine:poc": "node scripts/bench_engine_poc.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "phaser": "^3.90.0",
    "redis": "^4.7.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.4.2",
    "svelte": "^5.53.13",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.7"
  }
}
